{
  "version": 2,
  "builds": [
    {
      "src": "server.js",
      "use": "@vercel/node"
    },
    {
      "src": "index.html",
      "use": "@vercel/static"
    },
    {
      "src": "style.css",
      "use": "@vercel/static"
    },
    {
      "src": "script.js",
      "use": "@vercel/static"
    }
  ],
  "rewrites": [
    {
      "source": "/analyze/(.*)",
      "destination": "/server.js"
    },
    {
      "source": "/compare(.*)",
      "destination": "/server.js"
    }
  ]
}